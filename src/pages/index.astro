                font-size: 14px;
                font-family: 'Montserrat', sans-serif;
                box-shadow: 0 4px 16px rgba(0,0,0,0.3);
                pointer-events: none;
            }

            /* En móvil — botones todavía más visibles */
            @media (max-width: 768px) {
                #btn-cerrar-mapa {
                    top: 16px;
                    right: 16px;
                    padding: 12px 22px;
                    font-size: 16px;
                }
                #indicador-mapa {
                    top: 16px;
                    left: 16px;
                    padding: 10px 14px;
                    font-size: 12px;
                }
            }
        </style>
	</body>
