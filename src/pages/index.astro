---
import "../styles/global.css";
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>La Katherina — Loteo a orillas del Río Paraná | Paso de la Patria, Corrientes</title>
		<meta name="description" content="Tu lugar de paz a orillas del Río Paraná, en Paso de la Patria, Corrientes. Lotes con vista al río y lagunas. Un desarrollo de Brios de Amanecer." />
	</head>
	<body>
		<!-- HERO: Pantalla principal con video de fondo siempre visible -->
		<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
			
			<!-- Video de fondo (siempre presente en todas las vistas) -->
			<video 
				autoplay 
				muted 
				loop 
				playsinline
				poster="/hero-poster.jpg"
				class="absolute inset-0 w-full h-full object-cover"
			>
				<source src="/hero-katherina.mp4" type="video/mp4" />
			</video>

			<!-- Capa oscura encima del video -->
			<div class="absolute inset-0 bg-black/40"></div>
			<div class="absolute inset-0 bg-gradient-to-b from-black/30 via-transparent to-black/60"></div>
			
			<!-- ========================================== -->
			<!-- VISTA 1: PORTADA (lo que ven al entrar) -->
			<!-- ========================================== -->
			<div id="vista-portada" class="relative z-10 text-center px-6 max-w-4xl mx-auto py-20">
				
				<!-- Logo La Katherina -->
				<div class="mb-10 flex justify-center">
					<img 
						src="/logo-katherina-blanco.png" 
						alt="La Katherina Club de Campo" 
						class="w-64 md:w-80 h-auto drop-shadow-2xl"
					/>
				</div>

				<p class="text-katherina-dorado-claro text-sm md:text-base tracking-[0.3em] uppercase mb-6 font-medium drop-shadow-lg">
					Bienvenido a tu lugar en el mundo
				</p>

				<h1 class="font-serif text-5xl md:text-7xl text-white mb-6 leading-tight drop-shadow-2xl">
					Donde el río <em class="text-katherina-dorado-claro italic">abraza</em><br/>
					la tranquilidad
				</h1>

				<p class="text-white/90 text-lg md:text-xl max-w-2xl mx-auto mb-12 leading-relaxed drop-shadow-lg">
					Un loteo único a orillas del Río Paraná, en Paso de la Patria, Corrientes.
					Lotes con vista al río y lagunas, en un entorno natural, seguro y exclusivo.
				</p>

				<!-- Botón VER LOTEO -->
				<div class="flex justify-center">
					<button 
						type="button"
						onclick="mostrarOpciones()"
						class="bg-katherina-verde hover:bg-katherina-verde-oscuro text-white px-10 py-4 rounded-full text-sm tracking-widest uppercase transition-all duration-300 shadow-2xl hover:scale-105 cursor-pointer"
					>
						Ver Loteo
					</button>
				</div>

				<!-- Sello Brios de Amanecer -->
				<div class="mt-20 flex flex-col items-center gap-3">
					<p class="text-white/70 text-xs uppercase tracking-widest drop-shadow-lg">Un desarrollo de</p>
					<img 
						src="/logo-brios-blanco.png" 
						alt="Brios de Amanecer Desarrolladora" 
						class="h-20 md:h-24 w-auto drop-shadow-2xl"
					/>
					<p class="text-white/70 text-xs italic drop-shadow-lg">Más de 15 años de trayectoria</p>
				</div>
			</div>

			<!-- ========================================== -->
			<!-- VISTA 2: 3 OPCIONES (Plano, Imágenes, Video) -->
			<!-- ========================================== -->
			<div id="vista-opciones" class="hidden relative z-10 text-center px-6 max-w-4xl mx-auto py-20">
				
				<!-- Logo La Katherina (más chico) -->
				<div class="mb-8 flex justify-center">
					<img 
						src="/logo-katherina-blanco.png" 
						alt="La Katherina" 
						class="w-48 md:w-64 h-auto drop-shadow-2xl"
					/>
				</div>

				<!-- Subtítulo -->
				<p class="text-katherina-dorado-claro text-sm md:text-base tracking-[0.3em] uppercase mb-10 font-medium drop-shadow-lg">
					Conocé el loteo
				</p>

				<!-- Los 3 botones chiquitos centrados -->
				<div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-12">
					<button 
						type="button"
						onclick="mostrarPlano()"
						class="w-64 sm:w-auto bg-white/10 backdrop-blur-md border-2 border-white/30 hover:border-katherina-dorado-claro hover:bg-white/20 text-white px-8 py-4 rounded-full text-sm tracking-widest uppercase transition-all duration-300 cursor-pointer"
					>
						Plano del Loteo
					</button>

					<button 
						type="button"
						onclick="mostrarImagenes()"
						class="w-64 sm:w-auto bg-white/10 backdrop-blur-md border-2 border-white/30 hover:border-katherina-dorado-claro hover:bg-white/20 text-white px-8 py-4 rounded-full text-sm tracking-widest uppercase transition-all duration-300 cursor-pointer"
					>
						Imágenes
					</button>

					<button 
						type="button"
						onclick="mostrarVideo()"
						class="w-64 sm:w-auto bg-white/10 backdrop-blur-md border-2 border-white/30 hover:border-katherina-dorado-claro hover:bg-white/20 text-white px-8 py-4 rounded-full text-sm tracking-widest uppercase transition-all duration-300 cursor-pointer"
					>
						Video
					</button>
				</div>

				<!-- Botón Volver -->
				<button 
					type="button"
					onclick="volverPortada()"
					class="text-white/70 hover:text-katherina-dorado-claro text-xs tracking-widest uppercase transition-colors cursor-pointer"
				>
					← Volver
				</button>
			</div>

			<!-- ========================================== -->
			<!-- VISTA 3: PLANO DEL LOTEO -->
			<!-- ========================================== -->
			<div id="vista-plano" class="hidden relative z-10 px-6 py-12 max-w-5xl mx-auto w-full">
				
				<!-- Botón Volver arriba -->
				<button 
					type="button"
					onclick="volverOpciones()"
					class="text-white/80 hover:text-katherina-dorado-claro mb-8 text-xs tracking-widest uppercase transition-colors cursor-pointer"
				>
					← Volver
				</button>

				<!-- Título -->
				<div class="text-center mb-10">
					<p class="text-katherina-dorado-claro text-xs tracking-[0.3em] uppercase mb-3">Sección</p>
					<h2 class="font-serif text-4xl md:text-5xl text-white drop-shadow-2xl">Plano del Loteo</h2>
				</div>

				<!-- Placeholder elegante -->
				<div class="bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-12 text-center">
					<div class="text-6xl mb-6">🗺️</div>
					<p class="text-white text-xl mb-2 font-serif">Próximamente</p>
					<p class="text-white/70 text-sm max-w-md mx-auto">
						Pronto vas a poder ver la mensura completa con los lotes disponibles, las lagunas, el río Paraná y el pórtico de acceso.
					</p>
				</div>
			</div>

			<!-- ========================================== -->
			<!-- VISTA 4: IMÁGENES -->
			<!-- ========================================== -->
			<div id="vista-imagenes" class="hidden relative z-10 px-6 py-12 max-w-5xl mx-auto w-full">
				
				<button 
					type="button"
					onclick="volverOpciones()"
					class="text-white/80 hover:text-katherina-dorado-claro mb-8 text-xs tracking-widest uppercase transition-colors cursor-pointer"
				>
					← Volver
				</button>

				<div class="text-center mb-10">
					<p class="text-katherina-dorado-claro text-xs tracking-[0.3em] uppercase mb-3">Sección</p>
					<h2 class="font-serif text-4xl md:text-5xl text-white drop-shadow-2xl">Galería de Imágenes</h2>
				</div>

				<div class="bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-12 text-center">
					<div class="text-6xl mb-6">📸</div>
					<p class="text-white text-xl mb-2 font-serif">Próximamente</p>
					<p class="text-white/70 text-sm max-w-md mx-auto">
						Pronto vas a ver una galería con las mejores fotos del lugar: el río, las lagunas, el atardecer y las vistas aéreas del loteo.
					</p>
				</div>
			</div>

			<!-- ========================================== -->
			<!-- VISTA 5: VIDEO en grande -->
			<!-- ========================================== -->
			<div id="vista-video" class="hidden relative z-10 px-6 py-12 max-w-5xl mx-auto w-full">
				
				<button 
					type="button"
					onclick="volverOpciones()"
					class="text-white/80 hover:text-katherina-dorado-claro mb-8 text-xs tracking-widest uppercase transition-colors cursor-pointer"
				>
					← Volver
				</button>

				<div class="text-center mb-10">
					<p class="text-katherina-dorado-claro text-xs tracking-[0.3em] uppercase mb-3">Sección</p>
					<h2 class="font-serif text-4xl md:text-5xl text-white drop-shadow-2xl">La Katherina en Video</h2>
					<p class="text-white/80 mt-4 max-w-2xl mx-auto">
						Recorrido aéreo de 45 segundos por el loteo
					</p>
				</div>

				<!-- Reproductor de video -->
				<div class="rounded-2xl overflow-hidden shadow-2xl bg-black">
					<video 
						id="video-grande"
						controls 
						playsinline
						poster="/hero-poster.jpg"
						class="w-full h-auto"
					>
						<source src="/hero-katherina.mp4" type="video/mp4" />
						Tu navegador no soporta video.
					</video>
				</div>
			</div>
<!-- Botones flotantes de WhatsApp e Instagram -->
			<div id="botones-flotantes" class="fixed bottom-6 left-6 z-50 flex flex-col gap-3">
				<!-- WhatsApp -->
				<a 
					href="https://wa.me/5493794809006?text=Hola%2C%20estoy%20interesado%20en%20el%20loteo%20la%20katherina%2C%20podr%C3%ADa%20enviarme%20informaci%C3%B3n"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="Consultar por WhatsApp"
					class="group relative w-14 h-14 md:w-16 md:h-16 bg-[#25D366] hover:bg-[#1ebe5a] rounded-full flex items-center justify-center shadow-2xl transition-all duration-300 hover:scale-110"
				>
					<svg viewBox="0 0 24 24" fill="white" class="w-7 h-7 md:w-8 md:h-8">
						<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
					</svg>
					<!-- Tooltip -->
					<span class="absolute left-full ml-3 px-3 py-1.5 bg-black/80 text-white text-xs rounded-lg whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
						WhatsApp
					</span>
				</a>

				<!-- Instagram -->
				<a 
					href="https://www.instagram.com/inmobiliaria.santalucia"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="Visitar Instagram de la inmobiliaria"
					class="group relative w-14 h-14 md:w-16 md:h-16 rounded-full flex items-center justify-center shadow-2xl transition-all duration-300 hover:scale-110"
					style="background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);"
				>
					<svg viewBox="0 0 24 24" fill="white" class="w-7 h-7 md:w-8 md:h-8">
						<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
					</svg>
					<!-- Tooltip -->
					<span class="absolute left-full ml-3 px-3 py-1.5 bg-black/80 text-white text-xs rounded-lg whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
						Instagram
					</span>
				</a>
			</div>
		</section>

		<!-- Script para cambiar entre vistas -->
		<script is:inline>
			function ocultarTodas() {
				document.getElementById('vista-portada').classList.add('hidden');
				document.getElementById('vista-opciones').classList.add('hidden');
				document.getElementById('vista-plano').classList.add('hidden');
				document.getElementById('vista-imagenes').classList.add('hidden');
				document.getElementById('vista-video').classList.add('hidden');
				
				// Pausar el video grande si está reproduciendo
				const videoGrande = document.getElementById('video-grande');
				if (videoGrande) {
					videoGrande.pause();
					videoGrande.currentTime = 0;
				}
			}

function mostrarOpciones() {
    ocultarTodas();
    document.getElementById('vista-opciones').classList.remove('hidden');
    document.getElementById('botones-flotantes').classList.remove('hidden');
    window.scrollTo(0, 0);
}
function volverPortada() {
    ocultarTodas();
    document.getElementById('vista-portada').classList.remove('hidden');
    document.getElementById('botones-flotantes').classList.remove('hidden');
    window.scrollTo(0, 0);
}
function volverOpciones() {
    ocultarTodas();
    document.getElementById('vista-opciones').classList.remove('hidden');
    document.getElementById('botones-flotantes').classList.remove('hidden');
    window.scrollTo(0, 0);
}
function mostrarPlano() {
    ocultarTodas();
    document.getElementById('vista-plano').classList.remove('hidden');
    document.getElementById('botones-flotantes').classList.add('hidden');
    window.scrollTo(0, 0);
}
function mostrarImagenes() {
    ocultarTodas();
    document.getElementById('vista-imagenes').classList.remove('hidden');
    document.getElementById('botones-flotantes').classList.add('hidden');
    window.scrollTo(0, 0);
}
function mostrarVideo() {
			ocultarTodas();
			document.getElementById('vista-video').classList.remove('hidden');
			window.scrollTo(0, 0);
			document.getElementById('botones-flotantes').classList.add('hidden');
			
			const videoGrande = document.getElementById('video-grande');
			if (videoGrande) {
				videoGrande.muted = false;
				videoGrande.play().catch(function() {
					videoGrande.muted = true;
					videoGrande.play();
				});
				
				setTimeout(function() {
					if (videoGrande.requestFullscreen) {
						videoGrande.requestFullscreen();
					} else if (videoGrande.webkitRequestFullscreen) {
						videoGrande.webkitRequestFullscreen();
					} else if (videoGrande.webkitEnterFullscreen) {
						videoGrande.webkitEnterFullscreen();
					}
				}, 300);
			}
		}
		</script>
	</body>
</html>
